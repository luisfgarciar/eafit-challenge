# ============================================================
# AI Chatbot — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_PORT=3000
LOG_LEVEL=3
AGENT_PACK_PATH=./agent-packs/my-agent

# ── LLM Provider ────────────────────────────────────────────
# Choose one provider and fill in the corresponding variables.

# Option A: OpenAI (requires paid API key)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1000

# Option B: Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option C: Ollama (local, free — needs ollama running separately)
# LLM_PROVIDER=ollama
# OLLAMA_ENDPOINT=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3

# ── VS Agent (Hologram DIDComm) ──────────────────────────────
# Set AGENT_ENDPOINT to your ngrok URL after running: ngrok http 3001
AGENT_ENDPOINT=https://your-subdomain.ngrok-free.app
VS_AGENT_ADMIN_URL=http://vs-agent:3001
EVENTS_BASE_URL=http://chatbot:3000

# ── Redis (memory + vector store) ────────────────────────────
REDIS_URL=redis://redis:6379
AGENT_MEMORY_BACKEND=redis
AGENT_MEMORY_WINDOW=8

# ── RAG / Vector Store ────────────────────────────────────────
RAG_PROVIDER=vectorstore
RAG_DOCS_PATH=/app/rag/docs
VECTOR_STORE=redis
VECTOR_INDEX_NAME=eafit-chatbot

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=eafit
POSTGRES_PASSWORD=eafit2025
POSTGRES_DB_NAME=chatbot-agent
