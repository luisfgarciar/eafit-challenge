# ============================================================
# AI Chatbot — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_PORT=3000
LOG_LEVEL=3
AGENT_PACK_PATH=./agent-packs/my-agent

# ── LLM Provider ────────────────────────────────────────────
# Choose one provider and fill in the corresponding variables.

# Option A: OpenAI (requires paid API key)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1000

# Option B: Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option C: Ollama (local, free — needs ollama running separately)
# LLM_PROVIDER=ollama
# OLLAMA_ENDPOINT=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3

# ── VS Agent (Hologram DIDComm) ──────────────────────────────
# Set AGENT_ENDPOINT to your ngrok URL after running: ngrok http 3001
AGENT_LABEL=EAFIT AI Assistant
AGENT_ENDPOINT=https://your-subdomain.ngrok-free.app
AGENT_ENDPOINTS=https://your-subdomain.ngrok-free.app
VS_AGENT_ADMIN_URL=http://vs-agent:3000
EVENTS_BASE_URL=http://chatbot:3000

# ── Verana Blockchain Verification ───────────────────────────
# Organization (parent service on Verana testnet)
ORG_VS_PUBLIC_URL=https://organization.eafit.testnet.verana.network
ORG_VS_ADMIN_URL=https://admin.organization.eafit.testnet.verana.network

# Service registration metadata (on-chain)
SERVICE_NAME=EAFIT AI Assistant
SERVICE_TYPE=AIAgent
SERVICE_DESCRIPTION=EAFIT AI chatbot with Verana blockchain verification and GitHub MCP integration
SERVICE_LOGO_URL=https://hologram.zone/images/github.svg
SERVICE_MIN_AGE=0
SERVICE_TERMS=https://verana.io/terms
SERVICE_PRIVACY=https://verana.io/privacy

# AnonCreds credential definition for user authentication (eafit-challenge avatar credDef)
CREDENTIAL_DEFINITION_ID=did:webvh:QmPZBrmehNXxY4eRL2a9F52sCfkQfToPHM8R427sNS2F1N:avatar.eafit.testnet.verana.network/resources/zQmdzYfqKe6ypc9NbRMHbCFvgnrqCwbWjBK2odKYrRePaTu

# ── MCP Integrations ──────────────────────────────────────────
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
# GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...   # optional default token; users can set their own via chat
MCP_CONFIG_ENCRYPTION_KEY=change-me-32-hex-chars

# ── Redis (memory + vector store) ────────────────────────────
REDIS_URL=redis://redis:6379
AGENT_MEMORY_BACKEND=redis
AGENT_MEMORY_WINDOW=8

# ── RAG / Vector Store ────────────────────────────────────────
RAG_PROVIDER=vectorstore
RAG_DOCS_PATH=/app/rag/docs
VECTOR_STORE=redis
VECTOR_INDEX_NAME=eafit-chatbot

# ── Stats (Artemis JMS broker) ────────────────────────────────
VS_AGENT_STATS_ENABLED=true
VS_AGENT_STATS_HOST=artemis
VS_AGENT_STATS_PORT=61616
VS_AGENT_STATS_QUEUE=stats-queue
VS_AGENT_STATS_USER=artemis
VS_AGENT_STATS_PASSWORD=artemis

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=eafit
POSTGRES_PASSWORD=eafit2025
POSTGRES_DB_NAME=chatbot-agent
